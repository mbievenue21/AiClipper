# =============================================================================
# AiClipper environment variables
# Copy this file to .env and fill in real values as you enable each feature.
# =============================================================================

# ----- Core paths (defaults work for local dev, no need to change) -----------
# SQLite database file. Both Next.js (Drizzle) and Python (SQLAlchemy)
# read/write this same file.
DATABASE_URL=file:./data/app.db

# Root folder for downloaded videos, generated clips, and thumbnails.
MEDIA_ROOT=./data/videos

# Python worker base URL (Next.js calls this to enqueue/inspect jobs).
WORKER_URL=http://localhost:8000

# Next.js public origin (used in OAuth redirect URIs).
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ----- AI: highlight detection (required) ------------------------------------
# Google AI Studio key for Gemini. Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Gemini model IDs. Defaults track the newest Gemini 3.x releases.
# Docs: https://ai.google.dev/gemini-api/docs/models
#   pro   -> gemini-3.1-pro-preview (deepest reasoning, preview)
#   flash -> gemini-3.5-flash       (newest STABLE, frontier, fast + cheap)
# The UI exposes "pro" / "flash" tiers; these map to the IDs below.
GEMINI_FLASH_MODEL=gemini-3.5-flash
GEMINI_PRO_MODEL=gemini-3.1-pro-preview
GEMINI_FLASH_LITE_MODEL=gemini-3.1-flash-lite
# Gemini 3.x reasoning effort: minimal | low | medium | high (default: low).
GEMINI_THINKING_LEVEL=low

# Optional: multimodal boundary refinement on suspect candidates (costly).
# Sends short video windows to Gemini for climax vs commentary detection.
GEMINI_MULTIMODAL_ENABLED=false
GEMINI_MULTIMODAL_MODEL=gemini-3.1-pro-preview

# Optional Tier-2 audio intelligence (parallel pass on audio.wav).
# ENRICHMENT_BACKEND=assemblyai | deepgram
ENRICHMENT_BACKEND=
ASSEMBLYAI_API_KEY=
DEEPGRAM_API_KEY=

# TwelveLabs v1.3 video-native analysis (optional)
# Uses assets + index-content upload, Pegasus 1.5 analyze, Marengo search.
# Docs: https://docs.twelvelabs.io/docs/get-started/introduction
TWELVELABS_ENABLED=false
TWELVELABS_API_KEY=
TWELVELABS_INDEX_ID=
TWELVELABS_MODEL_MARENGO=marengo3.0
TWELVELABS_MODEL_PEGASUS=pegasus1.5
# Chunking behavior for long VODs
TWELVELABS_MAX_ANALYZE_CHUNK_SECONDS=7200
TWELVELABS_CHUNK_OVERLAP_SECONDS=15
# Candidate behavior
TWELVELABS_MAX_SEARCH_RESULTS_PER_QUERY=10
TWELVELABS_VISUAL_CANDIDATE_LIMIT=40
TWELVELABS_MIN_VISUAL_CONFIDENCE=0.55
# Cost/safety controls
TWELVELABS_UPLOAD_FULL_VIDEO=true
TWELVELABS_REUSE_EXISTING_INDEX=true
TWELVELABS_FAIL_OPEN=true
# Max bytes per local ffmpeg split before TwelveLabs multipart asset upload (2 GB cap)
TWELVELABS_MAX_UPLOAD_BYTES=1900000000


# ----- AI: transcription (optional fallback) ---------------------------------
# We use local faster-whisper on your GPU by default. If you want to fall
# back to Groq's hosted Whisper API (fast + cheap), set this.
# Get one at: https://console.groq.com/keys
GROQ_API_KEY=

# Which transcription backend to use: "local" or "groq".
# Tip: Groq's hosted Whisper is ~$0.04/hour and ~50x faster than CPU local.
# For CPU-only setups it's the most pragmatic option.
TRANSCRIBE_BACKEND=local

# faster-whisper model: tiny | base | small | medium | large-v3
#
# CPU realtime ratios (Ryzen 7 / M1 class):
#   tiny    ~30x  (rough quality, fine for English-only smoke tests)
#   base    ~15x
#   small   ~6x   ← recommended CPU default. Great English quality.
#   medium  ~2x   (good quality, slow on CPU)
#   large-v3 ~0.5x (best quality, ~2x your audio duration on CPU)
#
# On a CUDA GPU with cuBLAS+cuDNN, large-v3 is ~15-30x realtime.
WHISPER_MODEL=small

# Compute type for faster-whisper on GPU: float16 (default) | int8_float16 | int8
# Auto-downgrades to int8 when device=cpu.
WHISPER_COMPUTE_TYPE=float16

# Device: auto (default) | cpu | cuda
# On Windows without CUDA Toolkit 12, use cpu — otherwise you may see
# "cublas64_12.dll is not found" and transcription will retry/fail.
# WHISPER_DEVICE=cpu

# Beam size: 1 = greedy decoding (fast, ~1% WER hit vs beam=5).
# Bump to 3 or 5 only if your content has heavy accents or terminology.
WHISPER_BEAM_SIZE=1

# Language hint skips Whisper's detection step (~3s saved on long files).
# Leave empty to let Whisper detect.
WHISPER_LANGUAGE=en

# CPU threads for CTranslate2. 0 = auto (all physical cores).
# Set to N-1 if you want to leave a core free for the OS during transcribe.
WHISPER_CPU_THREADS=0

# VAD silence trim threshold in milliseconds. Higher = more aggressive
# silence skipping = faster transcribe. 700ms is a safe sweet spot;
# drop to 500 if your content has fast back-and-forth dialog.
WHISPER_VAD_SILENCE_MS=700


# ----- AI: thumbnails (optional) ---------------------------------------------
# fal.ai key for Flux image generation as a fallback when no good source
# frame is available. Local frame extraction is the primary path.
FAL_API_KEY=


# ----- Default timezone (Step 12) --------------------------------------------
# Used when scheduling uploads. The user can pick any IANA timezone in the
# schedule dialog; this is just the initial selection (Central Standard).
DEFAULT_TIMEZONE=America/Chicago


# ----- YouTube upload (enable when ready) ------------------------------------
# Setup (one-time):
#   1. https://console.cloud.google.com/apis/library/youtube.googleapis.com
#      → "Enable" the YouTube Data API v3 for your project
#   2. https://console.cloud.google.com/apis/credentials/consent
#      → External user type, add yourself as a Test User
#      → Add scopes: ".../auth/youtube.upload" and ".../auth/youtube.readonly"
#   3. https://console.cloud.google.com/apis/credentials → "Create credentials"
#      → "OAuth client ID" → Application type: Web application
#      → Authorized redirect URI: http://localhost:3000/api/auth/youtube/callback
#   4. Copy the Client ID + Client Secret into the two lines below.
#   5. Restart `pnpm dev`, visit /accounts, click "Connect with YouTube".
#
# Required scopes: youtube.upload, youtube.readonly
# CLIENT_SECRET is required for the token-refresh path in the worker — without
# it the worker can upload while the access token is valid, but cannot renew.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/auth/youtube/callback


# ----- Instagram Reels publishing --------------------------------------------
# Uses the Instagram Business Login flow (the 2024 unified flow, no Facebook
# Page connection required). Your IG account must be Business or Creator —
# personal accounts CANNOT use the Content Publishing API.
#
# Setup (one-time):
#   1. https://developers.facebook.com/apps/ → "Create app"
#      → Use case: "Other" → App type: "Business"
#   2. In the app dashboard → Add product → "Instagram" → "API setup with
#      Instagram login" (NOT the legacy "Facebook Login for Business" path).
#   3. Under "1. Generate access tokens" / "2. Configure webhooks" you'll see
#      "Instagram app ID" + "Instagram app secret" — copy those below.
#   4. Under "3. Set up Instagram business login":
#        OAuth redirect URI: <your-app-url>/api/auth/instagram/callback
#        e.g. https://your-tunnel.trycloudflare.com/api/auth/instagram/callback
#      Instagram requires HTTPS — for local dev expose port 3000 via
#      Cloudflared/ngrok and set NEXT_PUBLIC_APP_URL above to that tunnel URL.
#   5. In your Meta app dashboard → App roles → "Roles" → add your IG account
#      as an "Instagram Tester" and accept the invite from instagram.com.
#   6. In the Instagram app → Settings → Account type → switch to "Business"
#      or "Creator" if it isn't already.
#   7. Restart `pnpm dev`, visit /accounts, click "Connect with Instagram".
#
# Publishing also needs NEXT_PUBLIC_APP_URL above to be a PUBLIC HTTPS URL —
# the worker constructs <NEXT_PUBLIC_APP_URL>/api/media/<clip> and hands that
# URL to Instagram, which fetches the video server-side.
#
# Required scopes (set automatically by /api/auth/instagram/start):
#   instagram_business_basic
#   instagram_business_content_publish
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/auth/instagram/callback
