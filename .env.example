# =============================================================================
# AiClipper environment variables
# Copy this file to .env and fill in real values as you enable each feature.
# =============================================================================

# ----- Core paths (defaults work for local dev, no need to change) -----------
# SQLite database file. Both Next.js (Drizzle) and Python (SQLAlchemy)
# read/write this same file.
DATABASE_URL=file:./data/app.db

# Root folder for downloaded videos, generated clips, and thumbnails.
MEDIA_ROOT=./data/videos

# Python worker base URL (Next.js calls this to enqueue/inspect jobs).
WORKER_URL=http://localhost:8000

# Next.js public origin (used in OAuth redirect URIs).
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ----- AI: highlight detection (required) ------------------------------------
# Google AI Studio key for Gemini 2.5 Flash. Free tier is generous.
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=


# ----- AI: transcription (optional fallback) ---------------------------------
# We use local faster-whisper on your GPU by default. If you want to fall
# back to Groq's hosted Whisper API (fast + cheap), set this.
# Get one at: https://console.groq.com/keys
GROQ_API_KEY=

# Which transcription backend to use: "local" or "groq".
TRANSCRIBE_BACKEND=local

# faster-whisper model: tiny | base | small | medium | large-v3
# large-v3 is best quality. On a strong NVIDIA GPU it's still fast.
WHISPER_MODEL=large-v3

# Compute type for faster-whisper on GPU: float16 (default) | int8_float16 | int8
WHISPER_COMPUTE_TYPE=float16


# ----- AI: thumbnails (optional) ---------------------------------------------
# fal.ai key for Flux image generation as a fallback when no good source
# frame is available. Local frame extraction is the primary path.
FAL_API_KEY=


# ----- YouTube upload (enable when ready) ------------------------------------
# OAuth 2.0 client credentials from Google Cloud Console:
# https://console.cloud.google.com/apis/credentials
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/auth/youtube/callback


# ----- TikTok upload (enable when ready) -------------------------------------
# Requires TikTok Developer app approval.
# https://developers.tiktok.com/
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:3000/api/auth/tiktok/callback
